---
import Navbar from '../components/Navbar.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}

const {
  title = '1.3 | 2.8 Digital Identity',
  description = 'Empowering Kerala SMEs with proper online presence and credibility through websites, Google, directories, socials, and data.',
  image = '/og-image.jpg',
  type = 'website'
} = Astro.props;

const siteName = '1.3 | 2.8 Digital Identity';
const siteUrl = Astro.site || 'https://onethree-twoeight.pages.dev';
const fullUrl = new URL(Astro.url.pathname, siteUrl).href;
const canonicalUrl = fullUrl;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;500;700&display=swap" rel="stylesheet">
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Primary Meta Tags -->
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, siteUrl).href} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={fullUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, siteUrl).href} />
    
    <!-- Additional SEO Meta Tags -->
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <meta name="author" content="1.3 | 2.8 Digital Identity" />
    <meta name="keywords" content="Kerala SME, digital presence, online credibility, website, Google, directories, social media, business growth" />
    
    <!-- Theme Color -->
    <meta name="theme-color" content="#7a9e7e" />
    
    <!-- Favicon (placeholder) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  </head>
  <body>
    <Navbar />
    <slot />
  </body>
</html>
