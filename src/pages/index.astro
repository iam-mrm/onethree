---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Welcome to Astro">
  <main class="min-h-screen flex items-center justify-center bg-gradient-to-r from-purple-500 to-pink-500">
    <div class="text-center text-white p-8">
      <h1 class="text-5xl font-bold mb-4">Welcome to Astro + Tailwind</h1>
      <p class="text-xl mb-6">Your project is ready to go!</p>
      <a href="https://docs.astro.build" target="_blank" class="inline-block bg-white text-purple-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
        Read the Docs
      </a>
    </div>
  </main>
</Layout>
