---
import Layout from '../layouts/Layout.astro';
import DigitalIdentity from '../components/DigitalIdentity.astro';
import ServiceCard from '../components/ServiceCard.astro';
---

<Layout 
  title="1.3 | 2.8 Digital Identity"
  description="Empowering Kerala SMEs with proper online presence and credibility through websites, Google, directories, socials, and data."
  image="/og-home.jpg"
>
  <header class="bg-white py-8 md:py-16 flex items-center justify-center max-w-3xl mx-auto px-4">
    <DigitalIdentity />
  </header>
  <main class="bg-white py-12 md:py-20 px-4 md:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-6 md:mb-8 tracking-tight" style="color: #2c3e50; font-family: 'Quicksand', sans-serif; font-weight: 700;">Empowering Kerala's SMEs</h1>
      <p class="text-lg md:text-2xl mb-8 md:mb-12 leading-relaxed font-medium" style="color: #7a9e7e; font-family: 'Quicksand', sans-serif; font-weight: 500;">
        Building proper online presence and credibility for businesses through websites, Google, directories, socials, and data.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 mt-8 md:mt-12 max-w-5xl mx-auto opacity-70">
      <ServiceCard 
        title="Website" 
        description="Professional digital presence" 
      />
      <ServiceCard 
        title="Google & Directories" 
        description="Enhanced local visibility" 
      />
      <ServiceCard 
        title="Socials & Data" 
        description="Strategic online growth" 
      />
    </div>
  </main>
</Layout>
