---
interface Props {
  showLabels?: boolean;
}

const { showLabels = true } = Astro.props;
---

<div class={`container ${showLabels ? 'with-labels' : 'without-labels'}`}>
  <div class="corner top-left"></div>
  <div class="corner top-right"></div>
  <div class="corner bottom-left"></div>
  <div class="corner bottom-right"></div>

  <div class="number dark">1.3</div>
  <div class="divider"></div>
  <div class="number green">2.8</div>

  {showLabels && (
    <>
      <div class="label center-fix">website</div>
      <div class="label ampersand">&</div>
      <div class="label center-fix">visibility</div>
    </>
  )}
</div>

<style>
  .container {
    position: relative;
    padding: 60px 80px;
    display: grid;
    grid-template-columns: 1fr 100px 1fr;
    justify-items: center;
    align-items: center;
  }

  .container.without-labels {
    padding: 20px 40px;
  }

  .number {
    font-size: 85px;
    font-weight: 700;
    line-height: 1;
    font-family: 'Quicksand', sans-serif;
  }

  .number.dark { color: #2c3e50; }
  .number.green { color: #7a9e7e; font-weight: 500; }

  .divider {
    grid-column: 2;
    width: 3px;
    height: 85px;
    background-color: #74a4bc;
  }

  .label {
    color: #2c3e50;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-top: 25px;
    white-space: nowrap;
    text-align: center;
    width: 100%;
    font-family: 'Quicksand', sans-serif;
  }

  .center-fix {
    padding-left: 0.3em;
  }

  .ampersand {
    letter-spacing: 0;
  }

  .corner {
    position: absolute;
    width: 60px;
    height: 20px;
    border: 1px solid #7a9e7e;
  }

  .top-left { top: 0; left: 0; border-right: none; border-bottom: none; }
  .top-right { top: 0; right: 0; border-left: none; border-bottom: none; }
  .bottom-left { bottom: 0; left: 0; border-right: none; border-top: none; }
  .bottom-right { bottom: 0; right: 0; border-left: none; border-top: none; }
</style>
